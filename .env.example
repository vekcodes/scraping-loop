# Required — used for the gpt-4o-mini page classification calls
OPENAI_API_KEY=sk-...

# Optional — a free Jina API key raises the r.jina.ai rate limit above ~20 RPM
JINA_API_KEY=

# Optional tuning (defaults shown)
MAX_PAGES_PER_SITE=8
MAX_CRAWL_DEPTH=2
JINA_TIMEOUT_SECONDS=15

# Count accuracy — upgrade the model for tricky sites; raise the
# content limit so long listing pages aren't truncated/undercounted.
CLASSIFIER_MODEL=gpt-4o-mini
MAX_CONTENT_CHARS=48000
